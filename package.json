  "lint-staged": {
    "src/**/*.{js,jsx}": [
      "eslint"
    ],
    "*.{test.js,spec.js}": [
      "jest --bail --findRelatedTests"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
