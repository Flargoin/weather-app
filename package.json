{
  "name": "weather-app",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "webpack serve --node-env=development",
    "dev": "webpack --node-env=development",
    "build": "webpack --node-env=production",
    "test": "jest --coverage --collectCoverageFrom=src/**/*.{js,jsx}",
    "lint": "eslint src",
    "clear": "rd /s /q dist",
